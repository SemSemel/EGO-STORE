            <a href="#" class="btn btn-primary">ابدأ الآن</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero" id="home">
        <div class="hero-content">
            <div class="hero-badge">
                <i class="fas fa-fire"></i>
                أكثر من 10,000 خلفية متحركة
            </div>
            <h1>خلفيات ألعاب <span>متحركة</span> بجودة 4K</h1>
            <p>أكبر متجر عربي لخلفيات الألعاب المتحركة. احصل على خلفيات حصرية لأشهر الألعاب بجودة سينمائية.</p>
            
            <div class="typing-text">
                <span class="cursor"></span>
                <span id="typing"></span>
            </div>

            <div class="hero-buttons" style="margin-top: 2rem;">
                <a href="#games" class="btn btn-primary" style="padding: 1rem 2.5rem; font-size: 1.1rem;">
                    <i class="fas fa-rocket"></i>
                    تصفح الخلفيات
                </a>
                <a href="#" class="btn btn-outline" style="padding: 1rem 2.5rem; font-size: 1.1rem;">
                    <i class="fas fa-play"></i>
                    شاهد العرض التوضيحي
                </a>
            </div>

            <div class="hero-stats">
                <div class="stat">
                    <div class="stat-number" data-target="10000">0</div>
                    <div class="stat-label">خلفية متاحة</div>
                </div>
                <div class="stat">
                    <div class="stat-number" data-target="5000">0</div>
                    <div class="stat-label">عميل سعيد</div>
                </div>
                <div class="stat">
                    <div class="stat-number" data-target="50">0</div>
                    <div class="stat-label">لعبة مدعومة</div>
                </div>
                <div class="stat">
                    <div class="stat-number" data-target="99">0</div>
                    <div class="stat-label">% رضا العملاء</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Marquee -->
    <div class="marquee">
        <div class="marquee-content">
            <div class="marquee-item"><i class="fas fa-check-circle"></i> جودة 4K فائقة</div>
            <div class="marquee-item"><i class="fas fa-bolt"></i> تحميل فوري</div>
            <div class="marquee-item"><i class="fas fa-shield-alt"></i> ضمان مدى الحياة</div>
            <div class="marquee-item"><i class="fas fa-sync"></i> تحديثات مستمرة</div>
            <div class="marquee-item"><i class="fas fa-headset"></i> دعم 24/7</div>
            <div class="marquee-item"><i class="fas fa-star"></i> تصنيف 5 نجوم</div>
            <div class="marquee-item"><i class="fas fa-check-circle"></i> جودة 4K فائقة</div>
            <div class="marquee-item"><i class="fas fa-bolt"></i> تحميل فوري</div>
            <div class="marquee-item"><i class="fas fa-shield-alt"></i> ضمان مدى الحياة</div>
            <div class="marquee-item"><i class="fas fa-sync"></i> تحديثات مستمرة</div>
            <div class="marquee-item"><i class="fas fa-headset"></i> دعم 24/7</div>
            <div class="marquee-item"><i class="fas fa-star"></i> تصنيف 5 نجوم</div>
        </div>
    </div>

    <!-- Games Section -->
